# Integration mode: official uses webhooks + private replies; legacy keeps browser automation.
INTEGRATION_MODE=official

# Legacy browser automation credentials
INSTAGRAM_USERNAME=preeti_varma._
INSTAGRAM_PASSWORD="preetivarma123"

# Official Instagram Graph API settings
INSTAGRAM_GRAPH_API_VERSION=v20.0
INSTAGRAM_PAGE_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=

# How often to poll for new comments (legacy mode only)
POLL_INTERVAL_SECONDS=60

# Delay between sending DMs to avoid spam detection (seconds, randomized within range)
DM_DELAY_MIN_SECONDS=8
DM_DELAY_MAX_SECONDS=20

# Max DMs to send per hour (safety cap)
MAX_DMS_PER_HOUR=30

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/automations.db

# Session file path (legacy mode only)
SESSION_FILE=./data/session.json

# App secret for basic dashboard auth (change this)
DASHBOARD_SECRET=changeme123
